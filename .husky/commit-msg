#!/usr/bin/env sh

commit_msg_file="$1"
commit_msg="$(cat "$commit_msg_file")"

# Allow merge and revert commits generated by git
if echo "$commit_msg" | grep -Eq '^(Merge|Revert) '; then
  exit 0
fi

# Enforce conventional commits: type(scope?)!?: subject
if ! echo "$commit_msg" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9\-]+\))?(!)?: .+'; then
  echo "Invalid commit message. Use Conventional Commits:" >&2
  echo "  <type>(<scope>): <subject>" >&2
  echo "  Example: feat(auth): add login endpoint" >&2
  exit 1
fi
