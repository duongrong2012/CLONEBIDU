# Social authentication
# Include every Google OAuth client ID allowed to authenticate with this backend.
GOOGLE_CLIENT_IDS=web-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com,ios-client-id.apps.googleusercontent.com

# Required for Zalo social login authorization-code exchange.
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret

# Password reset
PASSWORD_RESET_EXPIRES_MINUTES=15
FORGOT_PASSWORD_RATE_LIMIT_MS=30000

# SMTP email delivery for password reset.
# Required in production when using /auth-buyer/forgot-password.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM="Bidu Support <no-reply@example.com>"
